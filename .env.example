# ============================================================
# home-eink-display — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will never be committed.
# ============================================================

# ------------------------------------------------------------
# LTA DataMall API
# Register at: https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
# ------------------------------------------------------------
API_KEY=your_lta_datamall_api_key_here
API_BUS_URL=https://datamall2.mytransport.sg/ltaodataservice/v3/BusArrival
API_TRAIN_URL=https://datamall2.mytransport.sg/ltaodataservice/TrainServiceAlerts
API_BUS_STOP_INFO_URL=https://datamall2.mytransport.sg/ltaodataservice/BusStops

# ------------------------------------------------------------
# Bus Stop Configuration
# ------------------------------------------------------------
# Display header label for the bus stop (shown on screen)
A_HEADER=My Bus Stop

# Bus stop code (5-digit code from LTA, e.g. 83139)
BUS_STOP_CODE_A=12345

# ------------------------------------------------------------
# Journey Time (optional — set SHOW_JOURNEY_TIME=true to enable)
# ------------------------------------------------------------
SHOW_JOURNEY_TIME=false

# Comma-separated bus service numbers to track for journey time
BUS_SERVICES_TO_TRACK=970,156,77

# Full destination address for routing API
JOURNEY_DESTINATION=Your School or Destination, Singapore

# Short label shown on display (optional, falls back to JOURNEY_DESTINATION)
JOURNEY_DESTINATION_SHORT=Destination

# Routing provider: 'onemap' (free, SG) or 'google'
ROUTING_API_PROVIDER=onemap

# OneMap API token (optional, get at https://www.onemap.gov.sg/apidocs/)
ONEMAP_API_KEY=

# Google Maps Directions API key (required if ROUTING_API_PROVIDER=google)
GOOGLE_MAPS_API_KEY=

# How long to cache routing results in seconds (default 30 min)
JOURNEY_TIME_CACHE_DURATION=1800

# ------------------------------------------------------------
# Display Schedule
# ------------------------------------------------------------
# Hour of day (24h) to wake the display
WAKE_HOUR=7

# Hour of day (24h) to put display to sleep
SLEEP_HOUR=22

# Refresh interval during wake period (seconds)
WAKE_INTERVAL=30

# Refresh interval during sleep period (seconds)
SLEEP_INTERVAL=300

# Skip the time-of-day check entirely (useful for debugging)
DEBUG_SKIP_TIME_CHECK=false

# ------------------------------------------------------------
# Caching
# ------------------------------------------------------------
# How long to cache bus arrival and train disruption data in seconds
CACHE_DURATION=20

# ------------------------------------------------------------
# Home Assistant Integration
# Get a long-lived access token from HA: Profile → Long-Lived Access Tokens
# ------------------------------------------------------------
HOME_ASSISTANT_API_URL=http://homeassistant.local:8123/api

HOME_ASSISTANT_TOKEN=your_ha_long_lived_token_here

# HA weather entity to display
HOME_ASSISTANT_WEATHER_ENTITY=weather.home

# Full HA API URL for triggering sleep screen (optional)
HOME_ASSISTANT_SLEEP_URL=

# ------------------------------------------------------------
# Sleep Screen (HA Dashboard Screenshot via Puppeteer add-on)
# ------------------------------------------------------------
# Full URL of the HA dashboard to screenshot during sleep
SLEEP_SCREEN_DASHBOARD=http://homeassistant.local:8123/lovelace/eink

# Puppeteer e-ink mode (1=BW, 2=BWR)
SLEEP_SCREEN_EINK_MODE=2

# Puppeteer zoom level
SLEEP_SCREEN_ZOOM=1

# Puppeteer output format (optional)
SLEEP_SCREEN_FORMAT=

# Wait time in ms before screenshot
SLEEP_SCREEN_WAIT=5000

# HA theme to activate before screenshot
SLEEP_SCREEN_THEME=Graphite E-ink Light

# How long to cache weather data in seconds (default 30 min)
WEATHER_CACHE_DURATION=1800

# ------------------------------------------------------------
# MQTT (optional — set MQTT_ENABLED=true to enable)
# Allows Home Assistant to trigger display refreshes
# ------------------------------------------------------------
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_REFRESH=eink/display/refresh
MQTT_TOPIC_STATUS=eink/display/status

# ------------------------------------------------------------
# Web Config Panel (web_config.py)
# Access at http://<pi-ip>:5000 to edit .env without SSH
# ------------------------------------------------------------
WEB_CONFIG_PORT=5000
WEB_CONFIG_HOST=0.0.0.0
WEB_CONFIG_USERNAME=admin
# Generate a new hash with: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
WEB_CONFIG_PASSWORD_HASH=
WEB_CONFIG_SECRET_KEY=change_this_to_a_random_string

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
