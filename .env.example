# ============================================================
# home-eink-display — Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will never be committed.
# ============================================================

# ------------------------------------------------------------
# LTA DataMall API
# Register at: https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
# ------------------------------------------------------------
API_KEY=your_lta_datamall_api_key_here
API_BUS_URL=https://datamall2.mytransport.sg/ltaodataservice/v3/BusArrival
API_TRAIN_URL=https://datamall2.mytransport.sg/ltaodataservice/TrainServiceAlerts
API_BUS_STOP_INFO_URL=https://datamall2.mytransport.sg/ltaodataservice/BusStops

# ------------------------------------------------------------
# Bus Stop Configuration
# ------------------------------------------------------------
# Display header label for the bus stop (shown on screen)
A_HEADER=My Bus Stop

# Bus stop code (5-digit code from LTA, e.g. 83139)
BUS_STOP_CODE_A=12345

# ------------------------------------------------------------
# Journey Time (optional — set SHOW_JOURNEY_TIME=true to enable)
# ------------------------------------------------------------
SHOW_JOURNEY_TIME=false

# Comma-separated bus service numbers to track for journey time
BUS_SERVICES_TO_TRACK=970,156,77

# Full destination address for routing API
JOURNEY_DESTINATION=Your School or Destination, Singapore

# Short label shown on display (optional, falls back to JOURNEY_DESTINATION)
JOURNEY_DESTINATION_SHORT=Destination

# Routing provider: 'onemap' (free, SG) or 'google'
ROUTING_API_PROVIDER=onemap

# OneMap API token (optional, get at https://www.onemap.gov.sg/apidocs/)
ONEMAP_API_KEY=

# Google Maps Directions API key (required if ROUTING_API_PROVIDER=google)
GOOGLE_MAPS_API_KEY=

# How long to cache routing results in seconds (default 30 min)
JOURNEY_TIME_CACHE_DURATION=1800

# ------------------------------------------------------------
# Display Schedule (legacy fallback — see schedule_config.json.example
# for the real three-screen scheduler; these are only used to derive a
# default schedule if schedule_config.json is missing or invalid)
# ------------------------------------------------------------
# Hour of day (24h) to wake the display
WAKE_HOUR=7

# Hour of day (24h) to put display to sleep
SLEEP_HOUR=22

# Refresh interval while bus_train_screen/daytime_screen is active (seconds)
WAKE_INTERVAL=30

# Refresh interval while ha_screen is active (seconds)
SLEEP_INTERVAL=300

# Skip the scheduler entirely (always show bus_train_screen) — useful for debugging
DEBUG_SKIP_TIME_CHECK=false

# ------------------------------------------------------------
# Three-Screen Scheduler (ha_screen / bus_train_screen / daytime_screen)
# See schedule_config.json.example — copy to app/schedule_config.json
# ------------------------------------------------------------
# Path to the schedule JSON file (optional override)
SCHEDULE_CONFIG_PATH=

# ------------------------------------------------------------
# Day-Type Resolution (gates bus_train_screen to school days)
# ------------------------------------------------------------
HOME_ASSISTANT_SCHOOL_DAY_ENTITY=binary_sensor.school_day
HOME_ASSISTANT_WORKDAY_ENTITY=binary_sensor.workday_sensor

# Day-type assumed if Home Assistant is unreachable and no prior day's
# resolution is cached: school_day | work_day | off_day
DAY_TYPE_FALLBACK=work_day

# Testing override: force one screen regardless of schedule/day-type.
# One of: sleep_screen | bus_train_screen | daytime_screen | ha_screen
# Leave empty for normal schedule-driven behavior. Not meant to be left set
# in production - restart the service after changing this to pick it up.
FORCE_SCREEN=

# ------------------------------------------------------------
# Boot Connectivity Checklist
# ------------------------------------------------------------
# Per-check timeout in seconds (network/internet/LTA API/HA reachability)
BOOT_CHECK_TIMEOUT=3

# Lightweight URL used for the internet-reachability check
INTERNET_CHECK_URL=https://www.google.com/generate_204

# ------------------------------------------------------------
# Caching
# ------------------------------------------------------------
# How long to cache bus arrival and train disruption data in seconds
CACHE_DURATION=20

# ------------------------------------------------------------
# Home Assistant Integration
# Get a long-lived access token from HA: Profile → Long-Lived Access Tokens
# ------------------------------------------------------------
HOME_ASSISTANT_API_URL=http://homeassistant.local:8123/api

HOME_ASSISTANT_TOKEN=your_ha_long_lived_token_here

# HA weather entity to display
HOME_ASSISTANT_WEATHER_ENTITY=weather.home

# Full HA API URL for triggering ha_screen (optional). Renamed from
# HOME_ASSISTANT_SLEEP_URL — that name is still read as a fallback if this
# is unset, so existing .env files keep working.
HOME_ASSISTANT_DASHBOARD_URL=

# ------------------------------------------------------------
# ha_screen (HA Dashboard Screenshot via Puppeteer add-on)
# ------------------------------------------------------------
# Full URL of the HA dashboard to screenshot for ha_screen
SLEEP_SCREEN_DASHBOARD=http://homeassistant.local:8123/lovelace/eink

# Puppeteer e-ink mode (1=BW, 2=BWR)
SLEEP_SCREEN_EINK_MODE=2

# Puppeteer zoom level
SLEEP_SCREEN_ZOOM=1

# Puppeteer output format (optional)
SLEEP_SCREEN_FORMAT=

# Wait time in ms before screenshot
SLEEP_SCREEN_WAIT=5000

# HA theme to activate before screenshot
SLEEP_SCREEN_THEME=Graphite E-ink Light

# How long to cache weather data in seconds (default 30 min)
WEATHER_CACHE_DURATION=1800

# ------------------------------------------------------------
# MQTT (optional — set MQTT_ENABLED=true to enable)
# Allows Home Assistant to trigger display refreshes
# ------------------------------------------------------------
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_REFRESH=eink/display/refresh
MQTT_TOPIC_STATUS=eink/display/status
# Any message on this topic triggers a live reload of the schedule and
# FORCE_SCREEN (no restart needed) - see specifications.md's "Dynamic
# (no-restart) config reload" row. web_config.py publishes here automatically
# after a schedule save.
MQTT_TOPIC_CONFIG_RELOAD=eink/display/config_reload

# ------------------------------------------------------------
# Web Config Panel (web_config.py)
# Access at http://<pi-ip>:5000 to edit .env / the schedule without SSH.
# web_config.py REFUSES TO START if either of these two is unset or left as
# a known placeholder value (validate_web_config() startup guard) — there is
# no insecure fallback anymore.
# ------------------------------------------------------------
WEB_CONFIG_PORT=5000
WEB_CONFIG_HOST=0.0.0.0
WEB_CONFIG_USERNAME=admin
# Generate a new hash with: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
WEB_CONFIG_PASSWORD_HASH=
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEB_CONFIG_SECRET_KEY=

# ------------------------------------------------------------
# Secrets-at-rest encryption (app/secrets_vault.py)
# Protects .env values viewed/shared/committed in isolation — not a defense
# against full filesystem access to this device, since the key file lives on
# the same disk. Password-type fields saved through the web UI (API_KEY,
# GOOGLE_MAPS_API_KEY, ONEMAP_API_KEY, HOME_ASSISTANT_TOKEN, MQTT_PASSWORD)
# are stored with an "enc:" prefix going forward; existing plaintext values
# keep working untouched until re-saved once through the web UI.
# ------------------------------------------------------------
# Path to the encryption key file (optional override; auto-generated on
# first run if missing, gitignored, back it up)
SECRETS_KEY_PATH=

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
