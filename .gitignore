# Environment / secrets
.env
*.env

# Real schedule config (per-deployment) — schedule_config.json.example is the committed template
app/schedule_config.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# Compiled C extensions / ARM binaries (waveshare drivers)
*.so
*.pyc

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Pi-specific runtime files
*.pid

# Local render preview output (tools/preview_render.py)
tools/preview_output.png

# Demo / test bitmaps from upstream Waveshare project (large, not needed)
pic/*.bmp
pic/*.jpg
pic/*.jpeg
# Keep fonts in pic/ - explicitly unignore them
!pic/*.otf
!pic/*.ttf
!pic/*.ttc
!pic/Atkinson*/
