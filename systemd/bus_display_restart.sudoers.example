# Grants the web config panel (running as user pi) passwordless permission
# to restart bus_display.service, so the "Restart Service" button in the web
# UI works. Without this, /api/restart returns a permission-denied error.
#
# Install with:
#   sudo cp systemd/bus_display_restart.sudoers.example /etc/sudoers.d/bus_display_restart
#   sudo chmod 440 /etc/sudoers.d/bus_display_restart
#   sudo visudo -c   # validates syntax before it takes effect
#
# Adjust the username below if web_config.py runs as a different user.
#
# --no-block: web_config.py's /api/restart queues the restart and returns
# immediately rather than blocking on the full stop+start cycle (which can
# comfortably exceed a short HTTP timeout even when nothing is wrong).
# sudoers matches the command line exactly, so this entry must include it —
# if you're updating from an older install that only allowed the plain
# `restart bus_display` form, re-run the install steps above to pick up
# this line.
pi ALL=(ALL) NOPASSWD: /bin/systemctl restart --no-block bus_display
